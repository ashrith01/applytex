# Copy this file to .env and fill in your keys.
# .env is git-ignored; .env.example is safe to commit.

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=qwen/qwen3-32b
# Free tier cap: 6000 TPM total. Set to 4096 on paid (Dev) tier.
GROQ_MAX_TOKENS=1500

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (application-answer fallback) ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_APPLICATION=gpt-4o

# ── Codex SDK (uses Codex CLI/IDE/Web auth or API-key auth) ─────────────────
# Run `codex` once and sign in before using LLM_BACKEND=codex.
CODEX_MODEL=gpt-5.5
CODEX_MODEL_APPLICATION=gpt-5.4-mini
CODEX_SANDBOX=read_only

# ── Google Gemini (placeholder; backend not wired yet) ────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite

# ── Ollama (local, no key needed) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_MODEL_JD=qwen3:4b
OLLAMA_MODEL_PLAN=qwen3:8b
OLLAMA_MODEL_DIFF=qwen2.5-coder:7b
OLLAMA_MODEL_REFINE=qwen3:4b
OLLAMA_MODEL_REVIEW=qwen3:4b
OLLAMA_EMBEDDING_MODEL=embeddinggemma
OLLAMA_NUM_CTX=16384
LLM_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS_JD=1200
OLLAMA_MAX_TOKENS_PLAN=900
OLLAMA_MAX_TOKENS_DIFF=2200
OLLAMA_MAX_TOKENS_REFINE=700
OLLAMA_MAX_TOKENS_REVIEW=900

# ── Active backend: anthropic | groq | ollama | codex | openai ──────────────
LLM_BACKEND=ollama

# ── Optional per-task routing ────────────────────────────────────────────────
# Local 3-model setup for a 16 GB Apple Silicon Mac:
# - qwen3:4b for JD extraction and refinement.
# - qwen3:8b for ATS gap planning.
# - qwen2.5-coder:7b for LaTeX-safe structured diffs.
LLM_BACKEND_JD=ollama
LLM_BACKEND_PLAN=ollama
LLM_BACKEND_DIFF=ollama
LLM_BACKEND_REFINE=ollama
LLM_BACKEND_REVIEW=ollama
# Application answers default to Codex auth and use OpenAI only as a configured fallback.
LLM_BACKEND_APPLICATION=codex

# ── Optional LangSmith tracing ───────────────────────────────────────────────
# Enable to trace each optimization pipeline run, compare model latency/quality,
# and inspect accepted/rejected changes. Keep disabled for fully local runs.
SMARTJOBAPPLY_LANGSMITH_TRACE=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=applytex-local

# ── Local job/application storage ─────────────────────────────────────────────
APPLYTEX_DB_PATH=.applytex/applytex.db
# Legacy fallback still supported:
# SMARTJOBAPPLY_DB_PATH=.smartjobapply/smartjobapply.db
HOST=127.0.0.1
PORT=8000
